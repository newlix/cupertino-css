use flake "nixpkgs#nodejs_24"
# Playwright browsers from nixpkgs (must match @playwright/test version in package.json).
# Derivation path is resolved via nix eval; if the path isn't realised in /nix/store
# (never built, or GC'd), build it on demand so pnpm test works out of the box.
export PLAYWRIGHT_BROWSERS_PATH="$(nix eval nixpkgs#playwright-driver.browsers.outPath --raw 2>/dev/null)"
export PLAYWRIGHT_SKIP_BROWSER_DOWNLOAD=1
[ -n "$PLAYWRIGHT_BROWSERS_PATH" ] && [ ! -d "$PLAYWRIGHT_BROWSERS_PATH" ] && \
  nix build --no-link nixpkgs#playwright-driver.browsers >/dev/null 2>&1
