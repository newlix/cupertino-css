{% extends "_includes/layout.njk" %}
{% set title = "Installation" %}

{% block content %}

  <div class="mt-12 space-y-12 text-[15px] leading-relaxed text-foreground">

    <section>
      <h2>CDN</h2>
      <p class="mt-2 text-tertiary-foreground">The simplest way to get started. No build step needed.</p>
      <div class="snippet mt-4">
        <header>
          <span>HTML</span>
          <button aria-label="Copy code">Copy</button>
        </header>
        <pre><code class="language-html">&lt;link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/newlix/ciderui@main/dist/ciderui.cdn.min.css"&gt;

&lt;!-- Optional: interactive components --&gt;
&lt;script src="https://cdn.jsdelivr.net/gh/newlix/ciderui@main/js/cider.js"&gt;&lt;/script&gt;</code></pre>
      </div>
    </section>

    <section>
      <h2>Package Manager</h2>
      <p class="mt-2 text-tertiary-foreground">
        Requires <a href="https://tailwindcss.com/docs/installation" target="_blank" rel="noopener" class="text-primary underline underline-offset-4 hover:text-primary/80">Tailwind CSS v4</a>.
      </p>
      <div class="snippet mt-4">
        <header>
          <nav>
            <button data-tab="pm-npm" data-active>npm</button>
            <button data-tab="pm-pnpm">pnpm</button>
            <button data-tab="pm-bun">bun</button>
            <button data-tab="pm-yarn">yarn</button>
          </nav>
          <button aria-label="Copy code">Copy</button>
        </header>
        <pre data-panel="pm-npm" data-active><code class="language-bash">npm install ciderui@github:newlix/ciderui</code></pre>
        <pre data-panel="pm-pnpm"><code class="language-bash">pnpm add ciderui@github:newlix/ciderui</code></pre>
        <pre data-panel="pm-bun"><code class="language-bash">bun add github:newlix/ciderui</code></pre>
        <pre data-panel="pm-yarn"><code class="language-bash">yarn add ciderui@github:newlix/ciderui</code></pre>
      </div>
      <p class="mt-3">In your main CSS file:</p>
      <div class="snippet mt-3">
        <header>
          <span>CSS</span>
          <button aria-label="Copy code">Copy</button>
        </header>
        <pre><code class="language-css">@import "tailwindcss";
@import "ciderui";</code></pre>
      </div>
      <h3 class="mt-6 text-base font-semibold tracking-tight">Interactive Components <span class="text-sm font-normal text-tertiary-foreground">(Optional)</span></h3>
      <p class="mt-2 text-tertiary-foreground">
        Most components are pure CSS. For interactive behavior (dialogs, popovers, segmented controls, HUD, verification codes),
        include the JS bundle:
      </p>
      <div class="snippet mt-3">
        <header>
          <span>JS</span>
          <button aria-label="Copy code">Copy</button>
        </header>
        <pre><code class="language-js">import "ciderui/cider.js";</code></pre>
      </div>
    </section>

    <section>
      <h2>Activate Styles</h2>
      <p class="mt-2 text-tertiary-foreground">
        All Cider UI styles — classless elements and component classes — are scoped. Add <code>.cider</code> to an ancestor element to activate them.
      </p>
      <div class="snippet mt-4">
        <header>
          <span>HTML</span>
          <button aria-label="Copy code">Copy</button>
        </header>
        <pre><code class="language-html">&lt;!-- Full page --&gt;
&lt;body class="cider"&gt;
  &lt;h1&gt;Auto-styled heading&lt;/h1&gt;
  &lt;button class="btn-filled"&gt;Click me&lt;/button&gt;
&lt;/body&gt;

&lt;!-- Or scope to a section --&gt;
&lt;main class="cider"&gt;
  &lt;h1&gt;Styled here&lt;/h1&gt;
  &lt;p&gt;Native elements are styled automatically.&lt;/p&gt;
&lt;/main&gt;</code></pre>
      </div>
      <p class="mt-3 text-tertiary-foreground">
        Use <code>.cider-reset</code> to stop styles from leaking into nested third-party components.
        See <a href="components/essentials.html" class="text-primary underline underline-offset-4 hover:text-primary/80">Essentials</a> for details.
      </p>
    </section>

    <section>
      <h2>Dark Mode</h2>
      <p class="mt-2 text-tertiary-foreground">
        Cider UI uses a class-based dark mode. Add the <code>dark</code> class to your <code>&lt;html&gt;</code> element:
      </p>
      <div class="snippet mt-4">
        <header>
          <span>HTML</span>
          <button aria-label="Copy code">Copy</button>
        </header>
        <pre><code class="language-html">&lt;html class="dark"&gt;
  ...
&lt;/html&gt;</code></pre>
      </div>
      <p class="mt-3">Or toggle it with JavaScript:</p>
      <div class="snippet mt-3">
        <header>
          <span>JS</span>
          <button aria-label="Copy code">Copy</button>
        </header>
        <pre><code class="language-js">document.documentElement.classList.toggle('dark');</code></pre>
      </div>
    </section>

  </div>

{% endblock %}
