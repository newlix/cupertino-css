{% extends "_includes/layout.njk" %}
{% from "_includes/macros.njk" import example %}
{% set title = "Slider" %}
{% set description = "Draggable range input for selecting a numeric value." %}

{% block content %}

  <h2>Selectors</h2>
  <dl>
    <dt><code>.slider</code></dt>
    <dd>Range input styled as macOS-style slider with thumb and track.</dd>
  </dl>

  {% call example("Default") %}
<input type="range" min="0" max="100" value="33" class="slider w-full max-w-sm" aria-label="Value" />
{% endcall %}

  {% call example("With Label") %}
<label class="max-w-sm space-y-3">
  <div class="flex items-center justify-between">
    <span>Temperature</span>
    <span class="text-sm text-tertiary-foreground">70</span>
  </div>
  <input type="range" min="0" max="100" value="70" step="1" class="slider w-full" />
</label>
{% endcall %}

  {% call example("With Ticks") %}
<label class="max-w-sm space-y-3">
  <div class="flex items-center justify-between">
    <span>Volume</span>
    <span class="text-sm text-tertiary-foreground">50%</span>
  </div>
  <input type="range" min="0" max="100" value="50" step="25" class="slider w-full" />
  <div class="flex justify-between text-xs text-tertiary-foreground">
    <span>0</span>
    <span>25</span>
    <span>50</span>
    <span>75</span>
    <span>100</span>
  </div>
</label>
{% endcall %}

  {% call example("Disabled") %}
<input type="range" min="0" max="100" value="50" class="slider w-full max-w-sm" disabled aria-label="Disabled slider" />
{% endcall %}

  <section class="mt-12">
    <h2 class="text-xl font-bold tracking-tight">Usage</h2>
    <p class="mt-2 text-[15px] text-tertiary-foreground">Include the slider JS to enable the track fill effect. Without it, the filled portion of the track won't update as the slider moves.</p>
    <div class="snippet mt-4" style="border-radius: var(--radius-lg); overflow: hidden;">
      <pre><code class="language-html">&lt;!-- npm --&gt;
&lt;script src="node_modules/ciderui/js/slider.js"&gt;&lt;/script&gt;

&lt;!-- CDN --&gt;
&lt;script src="https://unpkg.com/ciderui/js/slider.js"&gt;&lt;/script&gt;</code></pre>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-bold tracking-tight">Accessibility</h2>
    <p class="mt-2 text-[15px] text-tertiary-foreground">Always pair a slider with a <code>&lt;label&gt;</code> or use <code>aria-label</code> so screen readers can identify its purpose. Native <code>&lt;input type="range"&gt;</code> exposes value, min, and max to assistive technology automatically.</p>
    <div class="snippet mt-4" style="border-radius: var(--radius-lg); overflow: hidden;">
      <pre><code class="language-html">&lt;!-- With label element --&gt;
&lt;label for="vol"&gt;Volume&lt;/label&gt;
&lt;input id="vol" type="range" class="slider" /&gt;

&lt;!-- With aria-label --&gt;
&lt;input type="range" aria-label="Volume" class="slider" /&gt;</code></pre>
    </div>
    <p class="mt-3 text-[15px] text-tertiary-foreground">Keyboard: use arrow keys to adjust value by step, Home/End to jump to min/max.</p>
  </section>

{% endblock %}
