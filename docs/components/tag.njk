{% extends "_includes/layout.njk" %}
{% from "_includes/macros.njk" import example %}
{% set title = "Tag" %}
{% set description = "Finder-style color dots for categorisation and labelling." %}

{% block content %}

  <h3>Selectors</h3>
  <dl>
    <dt><code>.tag-red</code></dt>
    <dd>Red Finder-style color dot.</dd>
    <dt><code>.tag-orange</code></dt>
    <dd>Orange color dot.</dd>
    <dt><code>.tag-yellow</code></dt>
    <dd>Yellow color dot.</dd>
    <dt><code>.tag-green</code></dt>
    <dd>Green color dot.</dd>
    <dt><code>.tag-blue</code></dt>
    <dd>Blue color dot.</dd>
    <dt><code>.tag-purple</code></dt>
    <dd>Purple color dot.</dd>
    <dt><code>.tag-gray</code></dt>
    <dd>Gray color dot.</dd>
  </dl>

  {% call example("Default") %}
<div class="flex items-center gap-1.5">
  <span class="tag-red"></span>
  <span class="tag-orange"></span>
  <span class="tag-yellow"></span>
  <span class="tag-green"></span>
  <span class="tag-blue"></span>
  <span class="tag-purple"></span>
  <span class="tag-gray"></span>
</div>
{% endcall %}

  {% call example("With Label") %}
<div class="flex flex-col gap-2">
  <label class="flex items-center gap-2 text-sm"><span class="tag-red"></span> Red</label>
  <label class="flex items-center gap-2 text-sm"><span class="tag-orange"></span> Orange</label>
  <label class="flex items-center gap-2 text-sm"><span class="tag-yellow"></span> Yellow</label>
  <label class="flex items-center gap-2 text-sm"><span class="tag-green"></span> Green</label>
  <label class="flex items-center gap-2 text-sm"><span class="tag-blue"></span> Blue</label>
  <label class="flex items-center gap-2 text-sm"><span class="tag-purple"></span> Purple</label>
  <label class="flex items-center gap-2 text-sm"><span class="tag-gray"></span> Gray</label>
</div>
{% endcall %}

  {% call example("Interactive") %}
<div class="flex items-center gap-1.5">
  <button class="tag-red" aria-label="Red"></button>
  <button class="tag-orange" aria-label="Orange"></button>
  <button class="tag-yellow" aria-label="Yellow"></button>
  <button class="tag-green" aria-label="Green"></button>
  <button class="tag-blue" aria-label="Blue"></button>
  <button class="tag-purple" aria-label="Purple"></button>
  <button class="tag-gray" aria-label="Gray"></button>
</div>
{% endcall %}

{% endblock %}
