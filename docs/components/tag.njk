{% extends "_includes/layout.njk" %}
{% from "_includes/macros.njk" import example %}
{% set title = "Tag" %}
{% set description = "Inline label for categorisation, filtering, or metadata." %}

{% block content %}

  <h3>Classes</h3>
  <dl>
    <dt><code>.tag</code></dt>
    <dd>Pill-shaped inline label with secondary background. Interactive when used as <code>&lt;button&gt;</code> or <code>&lt;a&gt;</code>.</dd>
  </dl>

  {% call example("Default") %}
<div class="flex flex-wrap items-center gap-2">
  <span class="tag">Swift</span>
  <span class="tag">UIKit</span>
  <span class="tag">macOS</span>
</div>
{% endcall %}

  {% call example("With Icon") %}
<div class="flex flex-wrap items-center gap-2">
  <span class="tag">
    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v8m-4-4h8"/></svg>
    New
  </span>
  <span class="tag">
    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 0 0 3 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 0 0 5.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 0 0 9.568 3Z"/><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6Z"/></svg>
    Label
  </span>
</div>
{% endcall %}

  {% call example("Interactive") %}
<div class="flex flex-wrap items-center gap-2">
  <button class="tag">
    Design
    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg>
  </button>
  <a href="#" class="tag">
    Documentation
    <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25"/></svg>
  </a>
</div>
{% endcall %}

  {% call example("Disabled") %}
<div class="flex flex-wrap items-center gap-2">
  <button class="tag" disabled>Archived</button>
  <a class="tag" aria-disabled="true">Read-only</a>
</div>
{% endcall %}

{% endblock %}
