{% extends "_includes/layout.njk" %}
{% from "_includes/macros.njk" import example %}
{% set title = "Separator" %}
{% set description = "Thin horizontal line to divide content sections." %}

{% block content %}

  <h2>Selectors</h2>
  <dl>
    <dt><code>&lt;hr&gt;</code></dt>
    <dd>Classless horizontal divider with default <code>my-4</code> spacing. Use <code>my-0</code> in cards/panels where sections manage their own padding. Use <code>invisible</code> for spacing without a visible line.</dd>
    <dt><code>.separator-vertical</code></dt>
    <dd>Vertical divider for inline layouts.</dd>
    <dt><code>.separator-label</code></dt>
    <dd>Centered text label with lines on both sides.</dd>
  </dl>

  {% call example("Horizontal") %}
<p class="text-sm">Content above</p>
<hr>
<p class="text-sm">Content below</p>
{% endcall %}

  {% call example("Inset") %}
<div class="space-y-2">
  <p class="text-sm">First item</p>
  <hr class="ms-4">
  <p class="text-sm">Second item</p>
  <hr class="ms-4">
  <p class="text-sm">Third item</p>
</div>
{% endcall %}

  {% call example("Vertical") %}
<div class="flex items-center gap-4 h-8">
  <span class="text-sm">Section A</span>
  <div class="separator-vertical" role="separator" aria-orientation="vertical"></div>
  <span class="text-sm">Section B</span>
  <div class="separator-vertical" role="separator" aria-orientation="vertical"></div>
  <span class="text-sm">Section C</span>
</div>
{% endcall %}

  {% call example("With Label") %}
<div class="separator-label" role="separator">or continue with</div>
{% endcall %}

  {% call example("In Profile Card") %}
<div class="max-w-xs">
  <div class="space-y-1">
    <h3 class="text-base font-semibold">Cider UI</h3>
    <small>Apple-aesthetic component library.</small>
  </div>
  <hr>
  <div class="flex items-center gap-4 text-sm">
    <div>
      <p class="font-medium">Framework</p>
      <small>Tailwind CSS</small>
    </div>
    <div class="separator-vertical h-8" role="separator" aria-orientation="vertical"></div>
    <div>
      <p class="font-medium">Version</p>
      <small>v2.4.0</small>
    </div>
    <div class="separator-vertical h-8" role="separator" aria-orientation="vertical"></div>
    <div>
      <p class="font-medium">Components</p>
      <small>40+</small>
    </div>
  </div>
</div>
{% endcall %}

{% endblock %}
