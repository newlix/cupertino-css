{% extends "_includes/layout.njk" %}
{% set title = "Kitchen Sink" %}
{% set description = "Every component on one page." %}

{% block content %}

  <!-- Typography -->
  <section class="mt-10">
    <h2 class="text-xl font-bold tracking-tight">Typography</h2>
    <div class="mt-4 space-y-4">
      <h1>Heading 1</h1>
      <h2>Heading 2</h2>
      <h3>Heading 3</h3>
      <h4>Heading 4</h4>
      <p>Design is not just what it looks like and feels like. Design is how it works. Every detail matters — the way text flows on a page, the spacing between elements, the careful balance of hierarchy.</p>
      <p>When done right, typography becomes invisible, letting the <a href="#">content speak for itself</a>.</p>
      <blockquote>Simplicity is the ultimate sophistication.</blockquote>
      <ul>
        <li>Clean, semantic HTML structure</li>
        <li>Apple-inspired design tokens</li>
        <li>Dark mode support built-in</li>
      </ul>
      <ol>
        <li>Install the Tailwind CSS plugin</li>
        <li>Import the ciderui stylesheet</li>
        <li>Start building beautiful interfaces</li>
      </ol>
      <p>Use the <code>@import "ciderui"</code> directive. Press <kbd>Cmd</kbd> + <kbd>K</kbd> to open the command palette. Use <mark>mark</mark> to highlight text. <small>This is helper text.</small></p>
      <div class="flex flex-wrap gap-2">
        <span class="text-xs text-tertiary-foreground">Design</span>
        <span class="text-xs text-tertiary-foreground">CSS</span>
        <span class="text-xs text-tertiary-foreground">Tailwind</span>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Buttons -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Button</h2>
    <div class="mt-4 flex flex-wrap items-center gap-3">
      <button class="btn-filled">Filled</button>
      <button class="btn-gray">Gray</button>
      <button class="btn-tinted">Tinted</button>
      <button class="btn-plain">Plain</button>
      <button class="btn-filled btn-destructive">Destructive</button>
      <button class="btn-filled" disabled>Disabled</button>
    </div>
    <div class="mt-3 flex flex-wrap items-center gap-3">
      <button class="btn-filled btn-small">Small</button>
      <button class="btn-filled">Default</button>
      <button class="btn-filled btn-large">Large</button>
      <button class="btn-filled btn-capsule">Capsule</button>
    </div>
  </section>

  <hr class="my-12">

  <!-- Form -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Form</h2>
    <div class="mt-4 space-y-5 max-w-md">
      <label class="space-y-2">Name
        <input type="text" placeholder="Enter your name" />
      </label>
      <label class="space-y-2">Email
        <input type="email" placeholder="name@example.com" />
      </label>
      <label class="space-y-2">Bio
        <textarea placeholder="Tell us about yourself" rows="3"></textarea>
      </label>
      <label class="space-y-2">Country
        <select>
          <option>United States</option>
          <option>United Kingdom</option>
          <option>Japan</option>
          <option>Taiwan</option>
        </select>
      </label>
      <label class="space-y-2">Volume
        <input type="range" class="slider" min="0" max="100" value="60" />
      </label>
      <div class="space-y-2.5">
        <label><input type="checkbox" /> I agree to the terms</label>
        <label><input type="checkbox" checked /> Subscribe to newsletter</label>
        <label><input type="checkbox" disabled /> Unavailable option</label>
      </div>
      <fieldset>
        <legend>Preferred contact</legend>
        <label><input type="radio" name="ks-contact" checked /> Email</label>
        <label><input type="radio" name="ks-contact" /> Phone</label>
        <label><input type="radio" name="ks-contact" /> Mail</label>
      </fieldset>
      <div class="space-y-2.5">
        <label class="inline-flex items-center gap-2.5 cursor-pointer">
          <input type="checkbox" role="switch" checked />
          <span class="text-sm">Notifications</span>
        </label>
        <label class="inline-flex items-center gap-2.5 cursor-pointer">
          <input type="checkbox" role="switch" />
          <span class="text-sm">Airplane Mode</span>
        </label>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Verification Code -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Verification Code</h2>
    <div class="mt-4">
      <div class="verification-code" data-name="ks-code">
        <input><input><input>
        <span>&ndash;</span>
        <input><input><input>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Card -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Card</h2>
    <div class="mt-4 grid gap-4 sm:grid-cols-2">
      <div class="card">
        <div class="flex items-center gap-3">
          <span class="avatar">
            <svg class="size-5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 .75-7.425A4.502 4.502 0 0 0 14.25 7.5a4.5 4.5 0 0 0-4.39 3.51A3 3 0 0 0 8.25 15h-6Z"/></svg>
          </span>
          <div>
            <h4>iCloud Storage</h4>
            <p class="text-sm text-tertiary-foreground">5 GB of 50 GB used</p>
          </div>
        </div>
        <div class="mt-4">
          <progress value="10" max="100" aria-label="iCloud storage usage"></progress>
        </div>
      </div>
      <div class="card">
        <h4>Weekly Summary</h4>
        <p class="text-sm text-tertiary-foreground mt-1">You closed 12 tasks this week. Keep up the great work.</p>
        <button class="btn-tinted btn-small mt-4">View Details</button>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Avatar & Badge -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Avatar &amp; Badge</h2>
    <div class="mt-4 flex items-center gap-6">
      <div class="flex items-center gap-3">
        <img class="avatar" src="https://i.pravatar.cc/40?img=1" alt="Avatar" />
        <img class="avatar" src="https://i.pravatar.cc/40?img=2" alt="Avatar" />
        <div class="avatar">JD</div>
        <div class="avatar">
          <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/></svg>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <span class="badge">3</span>
        <span class="badge">99+</span>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Callout -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Callout</h2>
    <div class="mt-4">
      <div class="callout">
        <h4>Software Update</h4>
        <p>A new version of macOS is available. Update now to get the latest features and security improvements.</p>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- List -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">List</h2>
    <div class="mt-4">
      <div class="list">
        <div>
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
          <div>
            <h3>Project Files</h3>
            <p>Last updated 2 hours ago</p>
          </div>
          <button class="btn-tinted btn-small">Open</button>
        </div>
        <a href="#">
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>
          <div>
            <h3>Profile verified</h3>
            <p>Click to view your profile settings.</p>
          </div>
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <div>
          <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
          <div>
            <h3>Security Alert</h3>
            <p>New login detected from unknown device.</p>
          </div>
          <button class="btn-tinted btn-small">Review</button>
        </div>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Table -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Table</h2>
    <div class="mt-4">
      <table>
        <thead>
          <tr>
            <th scope="col">Invoice</th>
            <th scope="col">Status</th>
            <th scope="col">Method</th>
            <th scope="col" class="text-right">Amount</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="font-medium">INV-001</td>
            <td>Paid</td>
            <td>Credit Card</td>
            <td class="text-right">$250.00</td>
          </tr>
          <tr>
            <td class="font-medium">INV-002</td>
            <td>Pending</td>
            <td>PayPal</td>
            <td class="text-right">$150.00</td>
          </tr>
          <tr>
            <td class="font-medium">INV-003</td>
            <td>Unpaid</td>
            <td>Bank Transfer</td>
            <td class="text-right">$350.00</td>
          </tr>
        </tbody>
        <tfoot>
          <tr>
            <td colspan="3" class="font-medium">Total</td>
            <td class="text-right font-semibold">$750.00</td>
          </tr>
        </tfoot>
      </table>
    </div>
  </section>

  <hr class="my-12">

  <!-- Segmented Control -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Segmented Control</h2>
    <div class="mt-4">
      <div class="segmented-control" data-tabs>
        <div data-tab-list>
          <div data-tab-indicator></div>
          <button data-tab="ks-seg-1" data-active>Overview</button>
          <button data-tab="ks-seg-2">Analytics</button>
          <button data-tab="ks-seg-3">Reports</button>
        </div>
        <div data-tab-panel="ks-seg-1" data-active>
          <p class="text-sm text-tertiary-foreground">Overview content here.</p>
        </div>
        <div data-tab-panel="ks-seg-2">
          <p class="text-sm text-tertiary-foreground">Analytics content here.</p>
        </div>
        <div data-tab-panel="ks-seg-3">
          <p class="text-sm text-tertiary-foreground">Reports content here.</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Breadcrumb -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Breadcrumb</h2>
    <div class="mt-4">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="#">Home</a>
        <a href="#">Components</a>
        <span aria-current="page">Kitchen Sink</span>
      </nav>
    </div>
  </section>

  <hr class="my-12">

  <!-- Pagination & Page Control -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Pagination &amp; Page Control</h2>
    <div class="mt-4 space-y-6">
      <nav class="pagination" aria-label="Pagination">
        <button aria-label="Previous page" disabled>
          <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
        </button>
        <button aria-current="page">1</button>
        <button>2</button>
        <button>3</button>
        <span>...</span>
        <button>10</button>
        <button aria-label="Next page">
          <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </button>
      </nav>
      <nav class="page-control" aria-label="Page control">
        <button aria-label="Page 1" aria-current="page"></button>
        <button aria-label="Page 2"></button>
        <button aria-label="Page 3"></button>
        <button aria-label="Page 4"></button>
        <button aria-label="Page 5"></button>
      </nav>
    </div>
  </section>

  <hr class="my-12">

  <!-- Progress & Activity Indicator -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Progress &amp; Activity Indicator</h2>
    <div class="mt-4 space-y-4">
      <progress value="60" max="100" aria-label="Progress"></progress>
      <progress value="35" max="100" aria-label="Progress"></progress>
      <div class="progress-indeterminate" role="progressbar" aria-label="Loading"></div>
      <div class="flex items-center gap-4 mt-2">
        <span class="activity-indicator activity-indicator-sm" role="status" aria-label="Loading"></span>
        <span class="activity-indicator" role="status" aria-label="Loading"></span>
        <span class="activity-indicator activity-indicator-lg" role="status" aria-label="Loading"></span>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Popover -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Popover</h2>
    <div class="mt-4 flex flex-wrap gap-4">
      <div class="popover">
        <button class="btn-tinted">Open Popover</button>
        <div popover>
          <h4 class="text-sm font-semibold">Dimensions</h4>
          <p class="mt-1 text-xs text-tertiary-foreground">Set the dimensions for the layer.</p>
          <div class="mt-3 space-y-2">
            <label class="space-y-2">Width
              <input type="text" value="100%" />
            </label>
          </div>
        </div>
      </div>
      <div class="popover popover-menu">
        <button class="btn-plain">
          Options
          <svg class="size-4 text-tertiary-foreground" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div popover>
          <button>Profile</button>
          <button>Settings</button>
          <hr />
          <button class="text-destructive">Sign Out</button>
        </div>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Dialog -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Dialog</h2>
    <div class="mt-4">
      <button onclick="openDialog(this.nextElementSibling)" class="btn-tinted">Open Dialog</button>
      <dialog class="dialog">
        <header>
          <h2>Save changes to "Untitled"?</h2>
          <p>Your changes will be lost if you don't save them.</p>
        </header>
        <footer>
          <button onclick="closeDialog(this.closest('dialog'))" class="btn-tinted">Don't Save</button>
          <button onclick="closeDialog(this.closest('dialog'))" class="btn-gray">Cancel</button>
          <button onclick="closeDialog(this.closest('dialog'))" class="btn-filled">Save</button>
        </footer>
      </dialog>
    </div>
  </section>

  <hr class="my-12">

  <!-- HUD -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">HUD</h2>
    <div class="mt-4 flex flex-wrap gap-3">
      <button class="btn-filled" onclick="showHUD('Settings saved')">Show HUD</button>
      <button class="btn-gray" onclick="showHUD('Copied to clipboard', { icon: '<svg fill=&quot;none&quot; stroke=&quot;currentColor&quot; stroke-width=&quot;2&quot; viewBox=&quot;0 0 24 24&quot;><path stroke-linecap=&quot;round&quot; stroke-linejoin=&quot;round&quot; d=&quot;M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 01-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 011.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 00-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 01-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 00-3.375-3.375h-1.5a1.125 1.125 0 01-1.125-1.125v-1.5a3.375 3.375 0 00-3.375-3.375H9.75&quot;/></svg>' })">Custom Icon</button>
    </div>
  </section>

  <hr class="my-12">

  <!-- Kbd -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Kbd</h2>
    <div class="mt-4 flex flex-wrap items-center gap-2">
      <kbd>&#8984;</kbd> + <kbd>K</kbd>
      <span class="mx-2 text-tertiary-foreground">|</span>
      <kbd>Ctrl</kbd> + <kbd>Shift</kbd> + <kbd>P</kbd>
      <span class="mx-2 text-tertiary-foreground">|</span>
      <kbd>Esc</kbd>
    </div>
  </section>

  <hr class="my-12">

  <!-- Tag -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Tag</h2>
    <div class="mt-4 flex flex-wrap items-center gap-3">
      <span class="tag-red"></span>
      <span class="tag-orange"></span>
      <span class="tag-yellow"></span>
      <span class="tag-green"></span>
      <span class="tag-blue"></span>
      <span class="tag-purple"></span>
      <span class="tag-gray"></span>
    </div>
  </section>

  <hr class="my-12">

  <!-- Gauge -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Gauge</h2>
    <div class="mt-4 flex items-center gap-6">
      <div class="gauge" style="--gauge-value: 0.65"><span>65%</span></div>
      <div class="gauge gauge-green" style="--gauge-value: 0.92"><span>92%</span></div>
      <div class="gauge gauge-destructive" style="--gauge-value: 0.25"><span>25%</span></div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Navbar -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Navigation Bar</h2>
    <div class="mt-4 rounded-xl overflow-hidden border">
      <nav class="navbar">
        <div>
          <a href="#">
            <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Back
          </a>
        </div>
        <span>Settings</span>
        <div>
          <button>Done</button>
        </div>
      </nav>
    </div>
  </section>

  <hr class="my-12">

  <!-- Toolbar -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Toolbar</h2>
    <div class="mt-4 rounded-xl overflow-hidden border">
      <div class="toolbar">
        <div class="toolbar-group">
          <button aria-label="Bold" data-tooltip="Bold">
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg>
          </button>
          <button aria-label="Italic" data-tooltip="Italic">
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><line x1="19" x2="10" y1="4" y2="4"/><line x1="14" x2="5" y1="20" y2="20"/><line x1="15" x2="9" y1="4" y2="20"/></svg>
          </button>
          <button aria-label="Underline" data-tooltip="Underline">
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 4v6a6 6 0 0 0 12 0V4"/><line x1="4" x2="20" y1="20" y2="20"/></svg>
          </button>
        </div>
        <div class="toolbar-spacer"></div>
        <button data-tooltip="Undo" aria-label="Undo">
          <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 7v6h6"/><path d="M21 17a9 9 0 0 0-9-9 9 9 0 0 0-6 2.3L3 13"/></svg>
        </button>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Separator -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Separator</h2>
    <div class="mt-4 space-y-4">
      <hr>
      <hr class="separator-inset">
      <div class="flex items-center gap-4" style="height: 32px;">
        <span class="text-sm text-tertiary-foreground">Left</span>
        <div class="separator-vertical"></div>
        <span class="text-sm text-tertiary-foreground">Right</span>
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Search Field -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Search Field</h2>
    <div class="mt-4 max-w-sm">
      <div class="search-field">
        <input type="search" placeholder="Search" />
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Stepper -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Stepper</h2>
    <div class="mt-4">
      <div class="stepper" data-stepper data-value="5" data-min="0" data-max="10"></div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Token Field -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Token Field</h2>
    <div class="mt-4 max-w-md">
      <div class="token-field" data-token-field>
        <span class="token">Design<button aria-label="Remove Design">&times;</button></span>
        <span class="token">CSS<button aria-label="Remove CSS">&times;</button></span>
        <input type="text" placeholder="Add tag…" />
      </div>
    </div>
  </section>

  <hr class="my-12">

  <!-- Tooltip -->
  <section>
    <h2 class="text-xl font-bold tracking-tight">Tooltip</h2>
    <div class="mt-4 flex items-center gap-4">
      <button class="btn-gray size-11 p-0" data-tooltip="Edit" aria-label="Edit">
