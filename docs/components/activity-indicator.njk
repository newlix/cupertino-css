{% extends "_includes/layout.njk" %}
{% from "_includes/macros.njk" import example %}
{% set title = "Activity Indicator" %}
{% set description = "Spinning loader for indeterminate wait states." %}

{% block content %}

  <h2>Selectors</h2>
  <dl>
    <dt><code>.activity-indicator</code></dt>
    <dd>Spinning indicator with 12 radial spokes.</dd>
    <dt><code>.activity-indicator-sm</code></dt>
    <dd>Small size (16px).</dd>
    <dt><code>.activity-indicator-md</code></dt>
    <dd>Medium size (37px).</dd>
    <dt><code>.activity-indicator-lg</code></dt>
    <dd>Large size (100px).</dd>
  </dl>

  {% call example("Sizes") %}
<div class="flex flex-wrap items-center gap-4">
  <span class="activity-indicator activity-indicator-sm"></span>
  <span class="activity-indicator"></span>
  <span class="activity-indicator activity-indicator-lg"></span>
</div>
{% endcall %}

  {% call example("Button") %}
<div class="flex flex-wrap items-center gap-4">
  <button class="btn-gray" disabled>
    <span class="activity-indicator activity-indicator-sm"></span>
    Loading…
  </button>
  <button class="btn-tinted" disabled>
    <span class="activity-indicator activity-indicator-sm"></span>
    Please wait
  </button>
  <button class="btn-filled" disabled>
    <span class="activity-indicator activity-indicator-sm"></span>
    Processing
  </button>
</div>
{% endcall %}

  <section class="mt-12">
    <h2 class="text-xl font-bold tracking-tight">Accessibility</h2>
    <p class="mt-2 text-[15px] text-tertiary-foreground">When used standalone, add <code>role="status"</code> and <code>aria-label</code> so screen readers announce the loading state. When inside a button with visible text, no extra attributes are needed.</p>
    <div class="snippet mt-4" data-active style="border-radius: var(--radius-lg); overflow: hidden;">
      <pre><code class="language-html">&lt;!-- Standalone spinner --&gt;
&lt;span class="activity-indicator" role="status" aria-label="Loading…"&gt;&lt;/span&gt;

&lt;!-- Inside button (no extra aria needed) --&gt;
&lt;button disabled&gt;
  &lt;span class="activity-indicator activity-indicator-sm"&gt;&lt;/span&gt;
  Loading…
&lt;/button&gt;</code></pre>
    </div>
  </section>

  <section class="mt-8">
    <h2 class="text-xl font-bold tracking-tight">Color</h2>
    <p class="mt-2 text-[15px] text-tertiary-foreground">The spinner inherits <code>currentColor</code>. Customize by setting the text color on the parent element.</p>
    <div class="snippet mt-4" data-active style="border-radius: var(--radius-lg); overflow: hidden;">
      <pre><code class="language-html">&lt;div class="text-destructive"&gt;
  &lt;span class="activity-indicator"&gt;&lt;/span&gt; Error…
&lt;/div&gt;</code></pre>
    </div>
  </section>

{% endblock %}
