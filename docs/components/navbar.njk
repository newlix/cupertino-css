{% extends "_includes/layout.njk" %}
{% from "_includes/macros.njk" import example %}
{% set title = "Navigation Bar" %}
{% set description = "iOS-style top navigation bar with title and actions." %}

{% block content %}

  <h2>Selectors</h2>
  <dl>
    <dt><code>.navbar</code></dt>
    <dd>Top navigation bar container. Uses CSS Grid for perfect title centering.</dd>

    <dt><code>.navbar-title</code></dt>
    <dd>Centered title text.</dd>

    <dt><code>.navbar-back</code></dt>
    <dd>Back button with chevron icon and label.</dd>

    <dt><code>.navbar-actions</code></dt>
    <dd>Right-aligned action buttons container.</dd>
  </dl>

  {% call example("Default") %}
<nav class="navbar" aria-label="Navigation">
  <a href="#" class="navbar-back">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
    Back
  </a>
  <span class="navbar-title">Inbox</span>
  <div class="navbar-actions">
    <button type="button" aria-label="Compose">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
    </button>
  </div>
</nav>
{% endcall %}

  {% call example("With Multiple Actions") %}
<nav class="navbar" aria-label="Navigation">
  <a href="#" class="navbar-back">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
    Back
  </a>
  <span class="navbar-title">Settings</span>
  <div class="navbar-actions">
    <button type="button" aria-label="Search">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
    </button>
    <button type="button" aria-label="More options">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="1"/><circle cx="12" cy="5" r="1"/><circle cx="12" cy="19" r="1"/></svg>
    </button>
  </div>
</nav>
{% endcall %}

  {% call example("Title Only") %}
<nav class="navbar" aria-label="Navigation">
  <div></div>
  <span class="navbar-title">Welcome</span>
  <div></div>
</nav>
{% endcall %}

{% endblock %}
