{% extends "_includes/layout.njk" %}
{% from "_includes/macros.njk" import example %}
{% set title = "Progress" %}
{% set description = "Horizontal bar showing task completion percentage." %}

{% block content %}

  <h2>Selectors</h2>
  <dl>
    <dt><code>&lt;progress&gt;</code></dt>
    <dd>Native HTML progress element — auto-styled inside <code>.cider</code> scope.</dd>
    <dt><code>.progress-indeterminate</code></dt>
    <dd>Single-div sliding bar animation for unknown-duration progress.</dd>
  </dl>

  {% call example("Default") %}
<progress value="60" max="100"></progress>
{% endcall %}

  {% call example("With Label") %}
<div class="space-y-2">
  <div class="flex items-center justify-between text-sm">
    <span class="font-medium">Uploading...</span>
    <span class="text-tertiary-foreground">73%</span>
  </div>
  <progress value="73" max="100"></progress>
</div>
{% endcall %}

  {% call example("Indeterminate") %}
<div class="progress-indeterminate" role="progressbar" aria-label="Loading"></div>
{% endcall %}

  {% call example("In Card") %}
<div class="card max-w-sm p-6">
  <div class="flex items-center justify-between">
    <h3 class="text-sm font-semibold">Storage</h3>
    <span class="text-xs text-tertiary-foreground">7.2 GB / 15 GB</span>
  </div>
  <div class="mt-3">
    <progress value="48" max="100"></progress>
  </div>
  <p class="mt-2 text-xs text-tertiary-foreground">48% of storage used. Upgrade for more space.</p>
</div>
{% endcall %}

  <section class="mt-12">
    <h2 class="text-xl font-bold tracking-tight">Usage Notes</h2>
    <ul class="mt-2 list-disc pl-5 space-y-1 text-[15px] text-tertiary-foreground">
      <li>Use <code>&lt;progress&gt;</code> when you know the completion percentage.</li>
      <li>Use <code>.progress-indeterminate</code> when duration is unknown (e.g., file processing).</li>
      <li>Hide indeterminate bars with <code>display: none</code> when not active to reduce battery usage on mobile.</li>
    </ul>
  </section>

  <section class="mt-12">
    <h2 class="text-xl font-bold tracking-tight">Accessibility</h2>
    <p class="mt-2 text-[15px] text-tertiary-foreground">The native <code>&lt;progress&gt;</code> element is accessible by default. For the indeterminate variant (<code>.progress-indeterminate</code>), add <code>role="progressbar"</code> and <code>aria-label</code> so screen readers can announce the loading state.</p>
    <div class="snippet mt-4" data-active style="border-radius: var(--radius-lg); overflow: hidden;">
      <pre><code class="language-html">&lt;div class="progress-indeterminate" role="progressbar" aria-label="Loading"&gt;&lt;/div&gt;</code></pre>
    </div>
  </section>

{% endblock %}
