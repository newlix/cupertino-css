{% extends "_includes/layout.njk" %}
{% from "_includes/macros.njk" import example %}
{% set title = "Progress" %}
{% set description = "Horizontal bar showing task completion percentage." %}

{% block content %}

  <h3>Selectors</h3>
  <dl>
    <dt><code>&lt;progress&gt;</code></dt>
    <dd>Native HTML progress element — auto-styled inside <code>.cider</code> scope.</dd>
    <dt><code>.progress</code></dt>
    <dd>Div-based track container for the progress bar.</dd>
    <dt><code>.progress-bar</code></dt>
    <dd>Filled bar inside the track (set width via style).</dd>
    <dt><code>.progress-sm</code></dt>
    <dd>Thinner track height.</dd>
    <dt><code>.progress-indeterminate</code></dt>
    <dd>Sliding bar animation for indeterminate progress.</dd>
  </dl>

  {% call example("Default") %}
<progress value="60" max="100"></progress>
{% endcall %}

  {% call example("With Label") %}
<div class="space-y-2">
  <div class="flex items-center justify-between text-sm">
    <span class="font-medium">Uploading...</span>
    <span class="text-tertiary-foreground">73%</span>
  </div>
  <progress value="73" max="100"></progress>
</div>
{% endcall %}

  {% call example("Small") %}
<progress class="progress-sm" value="45" max="100"></progress>
{% endcall %}

  {% call example("Div-based") %}
<div class="progress">
  <div class="progress-bar" style="width: 60%"></div>
</div>
{% endcall %}

  <p class="text-tertiary-foreground">
    For determinate progress, use the native <code>&lt;progress&gt;</code> element. For indeterminate or when you need more control, use the div-based <code>.progress</code> / <code>.progress-bar</code> pattern.
  </p>

  {% call example("Indeterminate") %}
<div class="progress progress-indeterminate">
  <div class="progress-bar"></div>
</div>
{% endcall %}

  {% call example("In Card") %}
<div class="card max-w-sm p-6">
  <div class="flex items-center justify-between">
    <h3 class="text-sm font-semibold">Storage</h3>
    <span class="text-xs text-tertiary-foreground">7.2 GB / 15 GB</span>
  </div>
  <div class="mt-3">
    <progress value="48" max="100"></progress>
  </div>
  <p class="mt-2 text-xs text-tertiary-foreground">48% of storage used. Upgrade for more space.</p>
</div>
{% endcall %}

{% endblock %}
