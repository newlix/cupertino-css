{
  "name": "ciderui",
  "version": "0.3.0",
  "description": "Apple-aesthetic UI components as a Tailwind CSS plugin",
  "license": "MIT",
  "author": "newlix",
  "repository": {
    "type": "git",
    "url": "https://github.com/newlix/ciderui"
  },
  "keywords": [
    "tailwindcss",
    "tailwind",
    "css",
    "components",
    "apple",
    "cider",
    "ui"
  ],
  "type": "module",
  "exports": {
    ".": "./src/css/ciderui.css",
    "./cdn": "./src/css/ciderui.cdn.css",
    "./cider.js": "./js/cider.js"
  },
  "files": [
    "src/css/",
    "js/",
    "dist/"
  ],
  "scripts": {
    "build": "tailwindcss -i src/css/ciderui.cdn.css -o dist/ciderui.cdn.css && tailwindcss -i src/css/ciderui.cdn.css -o dist/ciderui.cdn.min.css --minify",
    "build:docs": "node scripts/build-docs.js",
    "dev": "concurrently \"node scripts/build-docs.js --watch\" \"PORT=8000 node scripts/test-server.js\"",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@tailwindcss/cli": "^4.2.1",
    "concurrently": "^9.2.0",
    "highlight.js": "^11.11.1",
    "nunjucks": "^3.2.4",
    "prettier": "^3.8.1"
  }
}
