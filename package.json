{
  "name": "ciderui",
  "version": "0.5.1",
  "description": "Apple-aesthetic UI components as a Tailwind CSS plugin",
  "license": "MIT",
  "author": "newlix",
  "repository": {
    "type": "git",
    "url": "https://github.com/newlix/ciderui"
  },
  "keywords": [
    "tailwindcss",
    "tailwind",
    "css",
    "components",
    "apple",
    "cider",
    "ui"
  ],
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "exports": {
    ".": "./src/css/ciderui.css",
    "./cdn": "./src/css/ciderui.cdn.css",
    "./cider.js": {
      "types": "./js/cider.d.ts",
      "default": "./js/cider.js"
    },
    "./components/*": {
      "types": "./js/cider.d.ts",
      "default": "./js/components/*.js"
    }
  },
  "types": "./js/cider.d.ts",
  "files": [
    "src/css/",
    "js/",
    "dist/"
  ],
  "scripts": {
    "build": "npm run build:js && tailwindcss -i src/css/ciderui.cdn.css -o dist/ciderui.cdn.css && tailwindcss -i src/css/ciderui.cdn.css -o dist/ciderui.cdn.min.css --minify",
    "build:js": "node scripts/build-cider-js.js",
    "build:docs": "node scripts/build-docs.js",
    "dev": "concurrently \"node scripts/build-docs.js --watch\" \"PORT=8000 node scripts/test-server.js\"",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:types": "pnpm --package=typescript dlx tsc",
    "test:shared-imports": "node scripts/check-shared-imports.js",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "peerDependencies": {
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/cli": "^4.2.1",
    "axe-core": "^4.11.3",
    "concurrently": "^9.2.0",
    "highlight.js": "^11.11.1",
    "nunjucks": "^3.2.4",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2"
  }
}
