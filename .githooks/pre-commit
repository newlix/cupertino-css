#!/usr/bin/env bash
# Pre-commit: format staged files with Prettier, then re-stage.
# Enabled via `pnpm install` (package.json `prepare` sets core.hooksPath).
set -e

mapfile -t staged < <(git diff --cached --name-only --diff-filter=ACMR |
  grep -E '\.(js|ts|jsx|tsx|css|json|md|yml|yaml|html)$' || true)

[ ${#staged[@]} -eq 0 ] && exit 0

# If any js/components/*.js is staged, regenerate the CDN bundle and restage it.
if printf '%s\n' "${staged[@]}" | grep -q '^js/components/'; then
  node scripts/build-cider-js.js >/dev/null
  git add js/cider.js
  # Include the regenerated bundle in the prettier pass below.
  grep -qxF 'js/cider.js' <(printf '%s\n' "${staged[@]}") || staged+=("js/cider.js")
fi

# If any CSS source is staged, regenerate dist/ (CDN bundle) and restage it.
# Skips if tailwindcss isn't resolvable (e.g. fresh clone pre-install) — CI
# still gates on the rebuild + diff.
if printf '%s\n' "${staged[@]}" | grep -qE '^src/css/'; then
  if [ -x node_modules/.bin/tailwindcss ]; then
    node_modules/.bin/tailwindcss -i src/css/ciderui.cdn.css -o dist/ciderui.cdn.css >/dev/null 2>&1
    node_modules/.bin/tailwindcss -i src/css/ciderui.cdn.css -o dist/ciderui.cdn.min.css --minify >/dev/null 2>&1
    git add dist/ciderui.cdn.css dist/ciderui.cdn.min.css
  fi
fi

if ! command -v npx >/dev/null 2>&1; then
  echo "pre-commit: npx not found; skipping prettier" >&2
  exit 0
fi

npx --no-install prettier --write "${staged[@]}" 2>/dev/null || \
  npx prettier --write "${staged[@]}"

git add "${staged[@]}"
